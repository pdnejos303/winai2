// ────────────────────────────────────────────────────────────────
// FILE: prisma/schema.prisma
// DESC: + Category table  |  Task.category → FK  (categoryId)
//       เก็บ icon ชื่อ lucide (string) 1-ครั้ง ใช้ร่วมหลาย Task
// ────────────────────────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* -----------------------------------------------------------------
 *  USER & AUTH TABLES (ไม่เปลี่ยน)
 * ----------------------------------------------------------------*/
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?

  Accounts      Account[]
  Sessions      Session[]
  Tasks         Task[]        // 🔥 1:N relation to Task
}

model Account {
  id                 Int    @id @default(autoincrement())
  userId             Int
  type               String
  provider           String
  providerAccountId  String
  access_token       String? @db.Text
  expires_at         Int?
  scope              String?
  id_token           String? @db.Text
  token_type         String?
  refresh_token      String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/* -----------------------------------------------------------------
 *  NEW TABLE: Category  (เก็บชื่อ + ไอคอน)
 * ----------------------------------------------------------------*/
model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique                      // เช่น Work, Health …
  icon  String                              // lucide icon name (เช่น "Briefcase")

  // ── relation ────────────────────────────────────────────────
  tasks Task[]                              // 1 : N  ← Task.categoryId
}

/* -----------------------------------------------------------------
 *  TASK TABLE (ปรับให้ใช้ FK categoryId)
 * ----------------------------------------------------------------*/
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  urgency     String                     // Urgent, Normal, Low
  status      String   @default("incompleted")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── relation to Category ───────────────────────────────────
  categoryId  Int?                       // FK (nullable ในกรณียังไม่เลือก)
  category    Category?  @relation(fields: [categoryId], references: [id])

  // ── relation to User ───────────────────────────────────────
  userId      Int
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}
